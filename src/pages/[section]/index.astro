---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { SECTIONS } from '../../consts';

export function getStaticPaths() {
  return SECTIONS.map((s) => ({ params: { section: s.slug } }));
}

const { section } = Astro.params;
const meta = SECTIONS.find((s) => s.slug === section)!;

const posts = (await getCollection('posts', ({ data }) => !data.draft && data.section === section)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title={meta.label} description={meta.description}>
  <h1>{meta.label}</h1>
  <p class="muted">{meta.description}</p>

  {posts.length === 0 && <p class="muted">这个板块还没有文章。</p>}
  {posts.map((post) => (
    <PostCard
      section={post.data.section}
      slug={post.id.split('/').pop()!}
      title={post.data.title}
      description={post.data.description}
      date={post.data.date}
    />
  ))}
</BaseLayout>
