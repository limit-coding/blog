---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <span class="muted">© {year} learnpath</span>
    <a href="/rss.xml">RSS</a>
    <a href="/about/">关于</a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 3rem;
  }

  .footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1.5rem 1.25rem;
    display: flex;
    gap: 1.25rem;
    align-items: center;
    font-size: 0.85rem;
  }

  .footer-inner a {
    color: var(--muted);
    text-decoration: none;
  }

  .footer-inner a:hover {
    color: var(--fg);
  }
</style>
