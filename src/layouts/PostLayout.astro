---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import { getSectionMeta } from '../consts';

interface NeighborPost {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  section: string;
  tags?: string[];
  cover?: ImageMetadata;
  prev?: NeighborPost;
  next?: NeighborPost;
}

const { title, description, date, updated, section, tags = [], cover, prev, next } = Astro.props;
const meta = getSectionMeta(section);
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header">
      {meta && <a class="tag" href={`/${meta.slug}/`}>{meta.label}</a>}
      <h1>{title}</h1>
      <div class="meta muted">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {updated && (
          <span>
            · 更新于 {updated.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
      )}
    </header>

    {cover && <Image class="cover" src={cover} alt="" widths={[400, 800, 1200]} sizes="(min-width: 700px) 700px, 100vw" />}

    <div class="prose">
      <slot />
    </div>

    {(prev || next) && (
      <nav class="neighbors">
        <a class="prev" href={prev?.href}>{prev && `← ${prev.title}`}</a>
        <a class="next" href={next?.href}>{next && `${next.title} →`}</a>
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  .post-header .tag {
    margin-bottom: 0.75rem;
  }

  .post-header h1 {
    margin-top: 0.25rem;
  }

  .meta {
    font-size: 0.9rem;
  }

  .tags {
    margin-top: 0.75rem;
  }

  .cover {
    width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }

  .prose :global(h2),
  .prose :global(h3) {
    scroll-margin-top: 1rem;
  }

  .neighbors {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
  }

  .neighbors a {
    text-decoration: none;
    color: var(--fg);
  }

  .neighbors a:hover {
    color: var(--accent);
  }

  .neighbors .next {
    text-align: right;
    margin-left: auto;
  }
</style>
